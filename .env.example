# ==============================================================
# SISTEMA ODONTOLÓGICO — Variáveis de Ambiente
# ==============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no git.
# ==============================================================

# Supabase
# Encontre em: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>

# Apenas para uso server-side (nunca exponha no front-end)
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
